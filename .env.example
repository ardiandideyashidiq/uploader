# This project supports YAML config (~/.config/uploader/config) as the primary method.
# Run interactive setup: uploader --setup
# Or set credentials manually in ~/.config/uploader/config:
#
# pixeldrain_key: your_pixeldrain_api_key
# gofile_key: your_gofile_api_key
# vikingfile_user: your_vikingfile_user
# telegram_bot_token: your_telegram_bot_token  # optional
# telegram_chat_id: your_telegram_chat_id  # optional

# Legacy .env file support (for backward compatibility):
# PIXELDRAIN_API_KEY=your_pixeldrain_api_key
# GOFILE_API_KEY=your_gofile_api_key
# VIKINGFILE_USER=your_vikingfile_user
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_telegram_chat_id

# Backward-compatible lowercase keys also work:
# pixeldrain=your_pixeldrain_api_key
# gofile=your_gofile_api_key
# vikingfile_user=your_vikingfile_user
# telegram_bot_token=your_telegram_bot_token
# telegram_chat_id=your_telegram_chat_id
